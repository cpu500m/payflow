
<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                           https://hibernate.org/xsd/orm/mapping/mapping-3.1.0.xsd">
    <access>FIELD</access>

    <entity class="com.payflow.wallet.domain.Wallet">
        <table name="wallet">
            <unique-constraint name="UK_WALLET_MEMBER_ID">
                <column-name>member_id</column-name>
            </unique-constraint>
        </table>
        <attributes>
            <basic name="memberId">
                <column name="member_id" nullable="false"/>
            </basic>
            <basic name="balance">
                <column name="balance" nullable="false"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
        </attributes>
    </entity>

    <entity class="com.payflow.wallet.domain.WalletTransaction">
        <table name="wallet_transaction"/>
        <attributes>
            <basic name="type">
                <column name="type" nullable="false" length="30"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="amount">
                <column name="amount" nullable="false"/>
            </basic>
            <basic name="description">
                <column name="description" length="100"/>
            </basic>
            <basic name="balanceAfter">
                <column name="balance_after" nullable="false"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
            <many-to-one name="wallet" fetch="LAZY">
                <join-column name="wallet_id" nullable="false"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>